// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // No custom output needed for Prisma 6
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WeatherQuery {
  id          Int      @id @default(autoincrement())
  location    String
  temp        Float    // Current temp at time of search
  description String
  
  // New Fields
  startDate   DateTime
  endDate     DateTime
  tempDay1    Float
  tempDay2    Float
  tempDay3    Float
  tempDay4    Float
  tempDay5    Float
  
  createdAt   DateTime @default(now())
}